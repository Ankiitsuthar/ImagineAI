# Environment Variables

# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/ai-image-saas

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Replicate API (for AI image generation - legacy)
REPLICATE_API_TOKEN=your_replicate_api_token_here

# Google Gemini API (for AI image generation)
GEMINI_API_KEY=your_gemini_api_key_here


# Hugging Face API (for AI image generation - Stable Diffusion XL via Replicate)
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=your_hugging_face_token_here

# GetImg.ai API (for AI image generation)
# Get your key from: https://getimg.ai/api
GETIMG_API_KEY=your_getimg_api_key_here

# Stripe (for payments)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Email Service (optional - for contact form notifications)
# ADMIN_EMAIL=admin@preweddingai.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# Google OAuth (optional - for social login)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
